#!/usr/bin/env python3
import sys
import os

VERSION = "0.2.00"

_REAL_FILE = os.path.realpath(__file__)
_BIN_DIR   = os.path.dirname(_REAL_FILE)
_ROOT_DIR  = os.path.dirname(_BIN_DIR)
CORE_DIR   = os.path.join(_ROOT_DIR, "truck", "core")

if not os.path.isdir(CORE_DIR):
    print(f"[trk] ERROR: truck/core not found at {CORE_DIR}")
    print("[trk] Re-run install.sh to fix installation.")
    sys.exit(1)

sys.path.insert(0, CORE_DIR)

HELP = f"""
  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—
     в–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қ
     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•—
     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—
     в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ
  Truck Package Manager for Asombi OS  v{VERSION}

Usage:
  trk install <package>     Install a package
  trk remove  <package>     Remove a package
  trk update  [package]     Update package(s)
  trk search  <query>       Search for packages
  trk list                  List installed packages
  trk info    <package>     Show package info
  trk repo    add <url>     Add a repository
  trk repo    remove <url>  Remove a repository
  trk repo    list          List repositories
  trk clean                 Clear cache
  trk version               Show version
"""


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(HELP)
        return

    cmd = args[0]
    rest = args[1:]

    if cmd == "version":
        print(f"Truck v{VERSION} | Asombi OS | ARM64/Android")
        return

    if cmd == "install":
        from install import cmd_install
        cmd_install(rest)
    elif cmd == "remove":
        from remove import cmd_remove
        cmd_remove(rest)
    elif cmd == "update":
        from update import cmd_update
        cmd_update(rest)
    elif cmd == "search":
        from search import cmd_search
        cmd_search(rest)
    elif cmd == "list":
        from list_pkg import cmd_list
        cmd_list(rest)
    elif cmd == "info":
        from info import cmd_info
        cmd_info(rest)
    elif cmd == "repo":
        from repo import cmd_repo
        cmd_repo(rest)
    elif cmd == "clean":
        from clean import cmd_clean
        cmd_clean()
    else:
        print(f"[trk] Unknown command: '{cmd}'")
        print("Run 'trk help' for usage.")
        sys.exit(1)


if __name__ == "__main__":
    main()
