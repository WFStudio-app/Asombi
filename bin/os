#!/usr/bin/env python3
# Asombi OS - Entry point
# Usage: os login <name> | os delete <name> | os instances | os version

import sys
import os
import json
import time
import subprocess
import urllib.request
import shutil

VERSION = "0.1.00"

_REAL_FILE = os.path.realpath(__file__)
_BIN_DIR   = os.path.dirname(_REAL_FILE)
ROOT_DIR   = os.path.dirname(_BIN_DIR)

sys.path.insert(0, os.path.join(ROOT_DIR, "wizzor", "core"))

from paths import (
    ASOMBI_ROOT, INSTANCES_DIR, INSTANCES_FILE, DATA_DIR,
    CACHE_DIR, PACKAGES_DIR, LOGS_DIR,
    instance_dir, instance_rootfs,
    ensure_dirs, size_of, human_size
)

ALPINE_VERSION   = "3.19"
ALPINE_URL_ARM64 = f"https://dl-cdn.alpinelinux.org/alpine/v{ALPINE_VERSION}/releases/aarch64/alpine-minirootfs-{ALPINE_VERSION}.0-aarch64.tar.gz"
ALPINE_URL_X86   = f"https://dl-cdn.alpinelinux.org/alpine/v{ALPINE_VERSION}/releases/x86_64/alpine-minirootfs-{ALPINE_VERSION}.0-x86_64.tar.gz"

COLORS = {
    "green":  "\033[92m", "red":    "\033[91m",
    "yellow": "\033[93m", "cyan":   "\033[96m",
    "reset":  "\033[0m",  "bold":   "\033[1m",
    "dim":    "\033[2m",
}

def c(color, text):
    return f"{COLORS.get(color,'')}{text}{COLORS['reset']}"

BANNER = (
    "\n"
    "\033[96m  ░█████╗░░██████╗░█████╗░███╗░░░███╗██████╗░██╗\033[0m\n"
    "\033[96m  ██╔══██╗██╔════╝██╔══██╗████╗░████║██╔══██╗██║\033[0m\n"
    "\033[96m  ███████║╚█████╗░██║░░██║██╔████╔██║██████╦╝██║\033[0m\n"
    "\033[96m  ██╔══██║░╚═══██╗██║░░██║██║╚██╔╝██║██╔══██╗██║\033[0m\n"
    "\033[96m  ██║░░██║██████╔╝╚█████╔╝██║░╚═╝░██║██████╦╝██║\033[0m\n"
    "\033[96m  ╚═╝░░╚═╝╚═════╝░╚════╝░╚═╝░░░╚═╝╚═════╝░╚═╝\033[0m\n"
    f"\033[2m  Asombi OS v{VERSION} | Sandbox Edition\033[0m\n"
)

def ok(msg):   print(c("green",  f"  [  OK  ] {msg}"))
def err(msg):  print(c("red",    f"  [ FAIL ] {msg}"))
def info(msg): print(c("cyan",   f"  [  ..  ] {msg}"))
def warn(msg): print(c("yellow", f"  [  !!  ] {msg}"))


def load_instances():
    ensure_dirs()
    if not os.path.exists(INSTANCES_FILE):
        return {}
    with open(INSTANCES_FILE) as f:
        return json.load(f)

def save_instances(data):
    ensure_dirs()
    with open(INSTANCES_FILE, "w") as f:
        json.dump(data, f, indent=2)

def get_arch():
    import platform
    m = platform.machine().lower()
    return "aarch64" if m in ("aarch64", "arm64") else "x86_64"

def check_proot():
    return shutil.which("proot") is not None

def boot_sequence(steps):
    for step in steps:
        sys.stdout.write(f"  {c('dim', '[ .... ]')} {step}")
        sys.stdout.flush()
        time.sleep(0.2)
        sys.stdout.write(f"\r  {c('green', '[  OK  ]')} {step}\n")
        sys.stdout.flush()


def download_alpine(rootfs_dir, arch):
    url     = ALPINE_URL_ARM64 if arch == "aarch64" else ALPINE_URL_X86
    tarball = os.path.join(CACHE_DIR, f"alpine-{arch}.tar.gz")

    info(f"Downloading Alpine Linux {ALPINE_VERSION} ({arch})...")

    def progress(count, block_size, total_size):
        if total_size > 0:
            pct = min(int(count * block_size * 100 / total_size), 100)
            bar = "█" * (pct // 5) + "░" * (20 - pct // 5)
            sys.stdout.write(f"\r  [{bar}] {pct}%")
            sys.stdout.flush()

    try:
        urllib.request.urlretrieve(url, tarball, reporthook=progress)
        print()
    except Exception as e:
        err(f"Download failed: {e}")
        return False

    ok("Download complete")
    info("Extracting rootfs...")
    os.makedirs(rootfs_dir, exist_ok=True)

    # ФИКС: используем системный tar вместо Python tarfile
    # Python tarfile отказывается от абсолютных симлинков
    # (например ./usr/bin/yes -> /bin/yes в Alpine busybox)
    # Системный tar в Termux обрабатывает их корректно
    ret = subprocess.run(
        ["tar", "-xzf", tarball, "-C", rootfs_dir],
        capture_output=True
    )
    if ret.returncode != 0:
        # Fallback: попробуем с --no-same-owner если есть ошибки прав
        ret2 = subprocess.run(
            ["tar", "-xzf", tarball, "-C", rootfs_dir,
             "--no-same-owner", "--no-same-permissions"],
            capture_output=True
        )
        if ret2.returncode != 0:
            err(f"Extraction failed: {ret2.stderr.decode().strip()}")
            return False

    # Удаляем tarball после успешной распаковки
    try:
        os.remove(tarball)
    except Exception:
        pass

    ok("Alpine rootfs ready")
    return True


def setup_inside(rootfs_dir, instance_name):
    # DNS
    etc = os.path.join(rootfs_dir, "etc")
    os.makedirs(etc, exist_ok=True)
    with open(os.path.join(etc, "resolv.conf"), "w") as f:
        f.write("nameserver 8.8.8.8\nnameserver 1.1.1.1\n")

    # /etc/profile
    with open(os.path.join(etc, "profile"), "w") as f:
        f.write(
            "#!/bin/sh\n"
            "# Asombi OS /etc/profile\n\n"
            f"export ASOMBI_INSTANCE=\"{instance_name}\"\n"
            f"export ASOMBI_VERSION=\"{VERSION}\"\n"
            "export TERM=xterm-256color\n"
            "export LANG=en_US.UTF-8\n"
            "export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin\n\n"
            "PS1='\\[\\033[96m\\]asombi\\[\\033[0m\\]@\\[\\033[92m\\]asombi-root"
            "\\[\\033[0m\\]:\\[\\033[93m\\]\\w\\[\\033[0m\\]# '\n"
            "export PS1\n\n"
            "for _f in /etc/profile.d/*.sh; do\n"
            "  [ -r \"$_f\" ] && . \"$_f\"\n"
            "done\nunset _f\n\n"
            "if command -v fastfetch >/dev/null 2>&1; then\n"
            "    fastfetch --config /root/.config/fastfetch/config.jsonc 2>/dev/null\n"
            "elif [ -f /root/.asombi/logo.txt ]; then\n"
            "    cat /root/.asombi/logo.txt\n"
            f"    echo '  Asombi OS v{VERSION}  |  {instance_name}'\n"
            "    echo '  wiz help — packages  |  exit — logout'\n"
            "fi\n"
        )

    # profile.d
    profiled = os.path.join(etc, "profile.d")
    os.makedirs(profiled, exist_ok=True)
    with open(os.path.join(profiled, "asombi.sh"), "w") as f:
        f.write("#!/bin/sh\nexport ASOMBI=1\n")

    # assets
    assets_src = os.path.join(ROOT_DIR, "assets")
    if os.path.exists(assets_src):
        for src, dst in [
            (os.path.join(assets_src, "fastfetch.jsonc"),
             os.path.join(rootfs_dir, "root", ".config", "fastfetch", "config.jsonc")),
            (os.path.join(assets_src, "logo.txt"),
             os.path.join(rootfs_dir, "root", ".asombi", "logo.txt")),
        ]:
            if os.path.exists(src):
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                shutil.copy2(src, dst)

    # Wizzor внутрь Alpine
    wiz_dst_dir = os.path.join(rootfs_dir, "usr", "local", "bin")
    os.makedirs(wiz_dst_dir, exist_ok=True)
    wiz_src = os.path.join(ROOT_DIR, "bin", "wiz")
    wiz_dst = os.path.join(wiz_dst_dir, "wiz")
    shutil.copy2(wiz_src, wiz_dst)
    os.chmod(wiz_dst, 0o755)

    # wizzor/core внутрь Alpine
    core_src = os.path.join(ROOT_DIR, "wizzor", "core")
    core_dst = os.path.join(rootfs_dir, "opt", "wizzor", "core")
    if os.path.exists(core_dst):
        shutil.rmtree(core_dst)
    shutil.copytree(core_src, core_dst)

    # Патч пути внутри Alpine
    with open(wiz_dst) as f:
        wiz_content = f.read()
    wiz_content = wiz_content.replace(
        "sys.path.insert(0, os.path.join(ROOT_DIR, \"wizzor\", \"core\"))",
        "sys.path.insert(0, \"/opt/wizzor/core\")"
    )
    with open(wiz_dst, "w") as f:
        f.write(wiz_content)

    ok("Wizzor installed inside Alpine")


def launch_proot(rootfs_dir):
    home = os.environ.get("HOME", "/data/data/com.termux/files/home")
    cmd = [
        "proot", "--kill-on-exit",
        "-r", rootfs_dir,
        "-b", "/dev",
        "-b", "/proc",
        "-b", "/sys",
        "-b", f"{home}:/termux-home",
        "-w", "/root",
        "/bin/sh", "-l",
    ]
    try:
        subprocess.run(cmd)
    except FileNotFoundError:
        err("proot not found. Install: pkg install proot")
        sys.exit(1)
    except KeyboardInterrupt:
        pass


def cmd_login(name):
    print(BANNER)
    print(f"  {c('bold', 'Booting instance:')} {c('cyan', name)}\n")

    if not check_proot():
        warn("proot not found. Installing...")
        os.system("pkg install proot -y 2>/dev/null")
        if not check_proot():
            err("Could not install proot. Run: pkg install proot")
            sys.exit(1)
    ok("proot found")

    ensure_dirs()
    rootfs = instance_rootfs(name)
    marker = os.path.join(rootfs, "etc", "alpine-release")

    if not os.path.exists(marker):
        info("First boot — setting up Alpine Linux...")
        arch = get_arch()
        ok(f"Architecture: {arch}")

        if not download_alpine(rootfs, arch):
            err("Alpine setup failed.")
            sys.exit(1)

        boot_sequence([
            "Configuring Alpine Linux",
            "Installing Wizzor package manager",
            "Setting up Asombi environment",
            "Configuring network DNS",
        ])

        setup_inside(rootfs, name)

        instances = load_instances()
        instances[name] = {
            "name":    name,
            "created": time.strftime("%Y-%m-%d %H:%M:%S"),
            "rootfs":  rootfs,
            "arch":    arch,
            "base":    f"Alpine Linux {ALPINE_VERSION}",
        }
        save_instances(instances)
        ok(f"Instance '{name}' ready")
    else:
        boot_sequence([
            "Loading Asombi kernel",
            "Mounting Alpine filesystem",
            "Starting session",
        ])

    print(f"\n  {c('green', '✓')} Entering Asombi OS — {c('cyan', name)}\n")
    time.sleep(0.3)
    launch_proot(rootfs)
    print(f"\n  {c('yellow', 'Session ended.')} Goodbye!\n")


def cmd_delete(args):
    if not args:
        err("Usage: os delete <name> | --all | --full")
        return

    instances = load_instances()
    flag = args[0]

    if flag == "--full":
        warn("This will delete ALL Asombi data:")
        print(f"  {ASOMBI_ROOT}")
        print(f"  Size: {human_size(size_of(ASOMBI_ROOT))}")
        confirm = input("\n  Are you sure? Type 'yes' to confirm: ").strip()
        if confirm != "yes":
            print("  Aborted.")
            return
        shutil.rmtree(ASOMBI_ROOT)
        ok("Asombi OS fully removed.")
        return

    if flag == "--all":
        if not instances:
            info("No instances to delete.")
            return
        warn(f"Deleting {len(instances)} instance(s):")
        for n in instances:
            print(f"  - {n}")
        confirm = input("\n  Are you sure? Type 'yes' to confirm: ").strip()
        if confirm != "yes":
            print("  Aborted.")
            return
        for n in list(instances.keys()):
            idir = instance_dir(n)
            if os.path.exists(idir):
                shutil.rmtree(idir)
            ok(f"Deleted: {n}")
        save_instances({})
        return

    name = flag
    if name not in instances:
        err(f"Instance '{name}' not found.")
        cmd_instances()
        return

    idir = instance_dir(name)
    size = human_size(size_of(idir)) if os.path.exists(idir) else "0 B"
    warn(f"Deleting instance '{name}' ({size})...")
    confirm = input("  Confirm? [y/N] ").strip().lower()
    if confirm != "y":
        print("  Aborted.")
        return
    if os.path.exists(idir):
        shutil.rmtree(idir)
    del instances[name]
    save_instances(instances)
    ok(f"Instance '{name}' deleted.")


def cmd_instances():
    instances = load_instances()
    if not instances:
        warn("No instances found.")
        print(f"  Create one: {c('cyan', 'os login asombi-1')}\n")
        return
    print(f"\n  {c('bold', 'Asombi instances:')}\n")
    for name, meta in instances.items():
        idir    = instance_dir(name)
        size    = human_size(size_of(idir)) if os.path.exists(idir) else "?"
        created = meta.get("created", "?")
        base    = meta.get("base", "?")
        print(f"  {c('cyan', name):<20} {base:<25} {size:<10} {c('dim', created)}")
    print()


def main():
    args = sys.argv[1:]

    if not args:
        print(BANNER)
        print(f"  Usage:")
        print(f"    {c('cyan', 'os login <name>')}         Start or create instance")
        print(f"    {c('cyan', 'os delete <name>')}        Delete instance (all files)")
        print(f"    {c('cyan', 'os delete --all')}         Delete all instances")
        print(f"    {c('cyan', 'os delete --full')}        Full removal (instances+cache+packages)")
        print(f"    {c('cyan', 'os instances')}            List all instances")
        print(f"    {c('cyan', 'os version')}              Show version\n")
        return

    cmd  = args[0]
    rest = args[1:]

    if cmd == "login":
        if not rest:
            err("Usage: os login <instance-name>")
            sys.exit(1)
        cmd_login(rest[0])
    elif cmd == "delete":
        cmd_delete(rest)
    elif cmd == "instances":
        cmd_instances()
    elif cmd == "version":
        print(f"  Asombi OS v{VERSION} | Alpine {ALPINE_VERSION}")
    else:
        err(f"Unknown command: '{cmd}'")
        print("  Run 'os' for help.")
        sys.exit(1)


if __name__ == "__main__":
    main()
