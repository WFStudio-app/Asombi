#!/usr/bin/env python3
# Asombi OS - Entry point
# Usage: os login <name> | os delete <name> | os instances | os version

import sys
import os
import json
import time
import subprocess
import urllib.request
import shutil
import socket

VERSION = "0.2.00"

_REAL_FILE = os.path.realpath(__file__)
_BIN_DIR   = os.path.dirname(_REAL_FILE)
ROOT_DIR   = os.path.dirname(_BIN_DIR)

sys.path.insert(0, os.path.join(ROOT_DIR, "truck", "core"))

from paths import (
    ASOMBI_ROOT, INSTANCES_DIR, INSTANCES_FILE, DATA_DIR,
    CACHE_DIR, PACKAGES_DIR, LOGS_DIR,
    instance_dir, instance_rootfs,
    ensure_dirs, size_of, human_size
)

ALPINE_VERSION   = "3.19"
ALPINE_URL_ARM64 = f"https://dl-cdn.alpinelinux.org/alpine/v{ALPINE_VERSION}/releases/aarch64/alpine-minirootfs-{ALPINE_VERSION}.0-aarch64.tar.gz"
ALPINE_URL_X86   = f"https://dl-cdn.alpinelinux.org/alpine/v{ALPINE_VERSION}/releases/x86_64/alpine-minirootfs-{ALPINE_VERSION}.0-x86_64.tar.gz"

COLORS = {
    "green":  "\033[92m", "red":    "\033[91m",
    "yellow": "\033[93m", "cyan":   "\033[96m",
    "reset":  "\033[0m",  "bold":   "\033[1m",
    "dim":    "\033[2m",
}

def c(color, text):
    return f"{COLORS.get(color,'')}{text}{COLORS['reset']}"

BANNER = (
    "\n"
    "\033[96m  ░█████╗░░██████╗░█████╗░███╗░░░███╗██████╗░██╗\033[0m\n"
    "\033[96m  ██╔══██╗██╔════╝██╔══██╗████╗░████║██╔══██╗██║\033[0m\n"
    "\033[96m  ███████║╚█████╗░██║░░██║██╔████╔██║██████╦╝██║\033[0m\n"
    "\033[96m  ██╔══██║░╚═══██╗██║░░██║██║╚██╔╝██║██╔══██╗██║\033[0m\n"
    "\033[96m  ██║░░██║██████╔╝╚█████╔╝██║░╚═╝░██║██████╦╝██║\033[0m\n"
    "\033[96m  ╚═╝░░╚═╝╚═════╝░╚════╝░╚═╝░░░╚═╝╚═════╝░╚═╝\033[0m\n"
    f"\033[2m  Asombi OS v{VERSION} | Sandbox Edition\033[0m\n"
)

def ok(msg):   print(c("green",  f"  [  OK  ] {msg}"))
def err(msg):  print(c("red",    f"  [ FAIL ] {msg}"))
def info(msg): print(c("cyan",   f"  [  ..  ] {msg}"))
def warn(msg): print(c("yellow", f"  [  !!  ] {msg}"))


def load_instances():
    ensure_dirs()
    if not os.path.exists(INSTANCES_FILE):
        return {}
    with open(INSTANCES_FILE) as f:
        return json.load(f)

def save_instances(data):
    ensure_dirs()
    with open(INSTANCES_FILE, "w") as f:
        json.dump(data, f, indent=2)

def get_platform():
    import platform
    return platform.system().lower()

def is_macos():
    return get_platform() == "darwin"

def is_linux():
    return get_platform() == "linux"

def get_arch():
    import platform
    m = platform.machine().lower()
    return "aarch64" if m in ("aarch64", "arm64") else "x86_64"

def check_proot():
    return shutil.which("proot") is not None

def check_lima():
    return shutil.which("lima") is not None or shutil.which("limactl") is not None

def launch_lima(rootfs_dir, instance_name):
    info("macOS detected — using Lima VM")
    if not check_lima():
        err("Lima not found. Install: brew install lima")
        err("Or run: bash install-macos.sh")
        sys.exit(1)
    ok("Lima found")
    lima_cfg = os.path.join(os.path.expanduser("~"), ".lima", "asombi", "lima.yaml")
    if not os.path.exists(lima_cfg):
        warn("Lima config not found — run install-macos.sh first")
        sys.exit(1)
    cmd = ["lima", "sudo", "proot",
           "--kill-on-exit", "--link2symlink", "-0",
           "-r", rootfs_dir,
           "-b", "/dev", "-b", "/proc", "-b", "/sys",
           "-w", "/root",
           "/bin/sh", "-l"]
    try:
        subprocess.run(cmd)
    except FileNotFoundError:
        err("Lima launch failed")
        sys.exit(1)
    except KeyboardInterrupt:
        pass

def boot_sequence(steps):
    for step in steps:
        sys.stdout.write(f"  {c('dim', '[ .... ]')} {step}")
        sys.stdout.flush()
        time.sleep(0.2)
        sys.stdout.write(f"\r  {c('green', '[  OK  ]')} {step}\n")
        sys.stdout.flush()


def download_alpine(rootfs_dir, arch):
    url     = ALPINE_URL_ARM64 if arch == "aarch64" else ALPINE_URL_X86
    tarball = os.path.join(CACHE_DIR, f"alpine-{arch}.tar.gz")

    info(f"Downloading Alpine Linux {ALPINE_VERSION} ({arch})...")

    def progress(count, block_size, total_size):
        if total_size > 0:
            pct = min(int(count * block_size * 100 / total_size), 100)
            bar = "█" * (pct // 5) + "░" * (20 - pct // 5)
            sys.stdout.write(f"\r  [{bar}] {pct}%")
            sys.stdout.flush()

    try:
        urllib.request.urlretrieve(url, tarball, reporthook=progress)
        print()
    except Exception as e:
        err(f"Download failed: {e}")
        return False

    ok("Download complete")
    info("Extracting rootfs...")
    os.makedirs(rootfs_dir, exist_ok=True)

    # ФИКС: используем системный tar вместо Python tarfile
    # Python tarfile отказывается от абсолютных симлинков
    # (например ./usr/bin/yes -> /bin/yes в Alpine busybox)
    # Системный tar в Termux обрабатывает их корректно
    ret = subprocess.run(
        ["tar", "-xzf", tarball, "-C", rootfs_dir],
        capture_output=True
    )
    if ret.returncode != 0:
        # Fallback: попробуем с --no-same-owner если есть ошибки прав
        ret2 = subprocess.run(
            ["tar", "-xzf", tarball, "-C", rootfs_dir,
             "--no-same-owner", "--no-same-permissions"],
            capture_output=True
        )
        if ret2.returncode != 0:
            err(f"Extraction failed: {ret2.stderr.decode().strip()}")
            return False

    # Удаляем tarball после успешной распаковки
    try:
        os.remove(tarball)
    except Exception:
        pass

    ok("Alpine rootfs ready")
    return True


def setup_inside(rootfs_dir, instance_name):
    # DNS
    etc = os.path.join(rootfs_dir, "etc")
    os.makedirs(etc, exist_ok=True)
    with open(os.path.join(etc, "resolv.conf"), "w") as f:
        f.write("nameserver 8.8.8.8\nnameserver 1.1.1.1\n")

    # /etc/profile
    with open(os.path.join(etc, "profile"), "w") as f:
        f.write(
            "#!/bin/sh\n"
            "# Asombi OS /etc/profile\n\n"
            f"export ASOMBI_INSTANCE=\"{instance_name}\"\n"
            f"export ASOMBI_VERSION=\"{VERSION}\"\n"
            "export TERM=xterm-256color\n"
            "export LANG=en_US.UTF-8\n"
            "export PATH=/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin\n\n"
            "PS1='\\[\\033[96m\\]asombi\\[\\033[0m\\]@\\[\\033[92m\\]asombi-root"
            "\\[\\033[0m\\]:\\[\\033[93m\\]\\w\\[\\033[0m\\]# '\n"
            "export PS1\n\n"
            "for _f in /etc/profile.d/*.sh; do\n"
            "  [ -r \"$_f\" ] && . \"$_f\"\n"
            "done\nunset _f\n\n"
            "if command -v fastfetch >/dev/null 2>&1; then\n"
            "    fastfetch --config /root/.config/fastfetch/config.jsonc 2>/dev/null\n"
            "elif [ -f /root/.asombi/logo.txt ]; then\n"
            "    cat /root/.asombi/logo.txt\n"
            f"    echo '  Asombi OS v{VERSION}  |  {instance_name}'\n"
            "    echo '  trk help — packages  |  exit — logout'\n"
            "fi\n"
        )

    # profile.d
    profiled = os.path.join(etc, "profile.d")
    os.makedirs(profiled, exist_ok=True)
    with open(os.path.join(profiled, "asombi.sh"), "w") as f:
        f.write("#!/bin/sh\nexport ASOMBI=1\n")

    # assets
    assets_src = os.path.join(ROOT_DIR, "assets")
    if os.path.exists(assets_src):
        for src, dst in [
            (os.path.join(assets_src, "fastfetch.jsonc"),
             os.path.join(rootfs_dir, "root", ".config", "fastfetch", "config.jsonc")),
            (os.path.join(assets_src, "logo.txt"),
             os.path.join(rootfs_dir, "root", ".asombi", "logo.txt")),
        ]:
            if os.path.exists(src):
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                shutil.copy2(src, dst)

    
    wiz_dst_dir = os.path.join(rootfs_dir, "usr", "local", "bin")
    os.makedirs(wiz_dst_dir, exist_ok=True)
    wiz_src = os.path.join(ROOT_DIR, "bin", "trk")
    wiz_dst = os.path.join(wiz_dst_dir, "trk")
    shutil.copy2(wiz_src, wiz_dst)
    os.chmod(wiz_dst, 0o755)

    # python3 + curl внутри Alpine — нужны для trk
    # Запускаем apk через proot внутрь только что распакованного rootfs
    apk_cmd = (
        f"proot --link2symlink -0 -r {rootfs_dir} "
        f"-b /dev -b /proc -b /sys "
        f"/bin/sh -c 'apk update -q 2>/dev/null && "
        f"apk add --no-cache python3 curl -q 2>/dev/null'"
    )
    apk_ret = os.system(apk_cmd)
    if apk_ret != 0:
        warn("python3/curl install via apk failed — trk may not work")
        warn("Inside Asombi run: apk add python3 curl")

    # truck/core внутрь Alpine
    core_src = os.path.join(ROOT_DIR, "truck", "core")
    core_dst = os.path.join(rootfs_dir, "opt", "truck", "core")
    if os.path.exists(core_dst):
        shutil.rmtree(core_dst)
    shutil.copytree(core_src, core_dst)

    
    # вместо хрупкой замены строки которой может не быть
    with open(wiz_dst) as f:
        wiz_content = f.read()
    # Убираем любые попытки вычислить CORE_DIR динамически
    # и вставляем жёсткий путь как первую строку после shebang
    lines = wiz_content.splitlines()
    shebang = lines[0] if lines and lines[0].startswith("#!") else ""
    rest = "\n".join(lines[1:]) if shebang else wiz_content
    # Фильтруем строки которые вычисляют CORE_DIR через realpath
    filtered = []
    skip_next = False
    for line in rest.splitlines():
        if any(x in line for x in [
            "_REAL_FILE", "_BIN_DIR", "_ROOT_DIR",
            "CORE_DIR", "os.path.realpath(__file__)",
            "sys.path.insert(0, CORE_DIR)",
            "sys.path.insert(0, os.path.join",
        ]):
            skip_next = False
            continue
        filtered.append(line)
    fixed_content = (
        (shebang + "\n" if shebang else "") +
        "# Asombi OS internal — path set by installer\n"
        "import sys\n"
        "sys.path.insert(0, \"/opt/truck/core\")\n" +
        "\n".join(filtered)
    )
    with open(wiz_dst, "w") as f:
        f.write(fixed_content)

    ok("Truck installed inside Alpine")


def check_rootfs(rootfs_dir):
    if not os.path.isdir(rootfs_dir):
        return False
    # lexists проверяет симлинки тоже (Alpine /bin/sh это симлинк на busybox)
    sh = os.path.join(rootfs_dir, "bin", "sh")
    busybox = os.path.join(rootfs_dir, "bin", "busybox")
    etc = os.path.join(rootfs_dir, "etc")
    usr = os.path.join(rootfs_dir, "usr")
    has_shell = os.path.lexists(sh) or os.path.lexists(busybox)
    has_dirs = os.path.isdir(etc) and os.path.isdir(usr)
    return has_shell and has_dirs


def launch_proot(rootfs_dir):
    # HOME всегда корректен в Termux, не хардкодим путь
    home = os.environ.get("HOME", "")
    if not home:
        err("HOME environment variable not set")
        sys.exit(1)
    cmd = [
        "proot",
        "--kill-on-exit",
        "--link2symlink",
        "-0",
        "-r", rootfs_dir,
        "-b", "/dev",
        "-b", "/proc",
        "-b", "/sys",
        "-b", f"{home}:/termux-home",
        "-w", "/root",
        "/bin/sh", "-l",
    ]
    try:
        subprocess.run(cmd)
        return True
    except FileNotFoundError:
        err("proot not found. Install: pkg install proot")
        sys.exit(1)
    except KeyboardInterrupt:
        pass
    return True



def check_network():
    try:
        socket.create_connection(("8.8.8.8", 53), timeout=5)
        return True
    except OSError:
        return False


def check_termux_mirror():
    mirrors = [
        "https://packages.termux.dev/apt/termux-main/",
        "https://grimler.se/termux/termux-main/",
        "https://termux.mentality.rip/termux-main/",
    ]
    for mirror in mirrors:
        try:
            req = urllib.request.Request(mirror, method="HEAD",
                                         headers={"User-Agent": "Asombi/0.2.00"})
            with urllib.request.urlopen(req, timeout=5) as r:
                if r.status == 200:
                    return True, mirror
        except Exception:
            continue
    return False, None


def install_termux_deps():
    deps = {
        "git":   "git",
        "python3": "python",
        "proot": "proot",
        "curl":  "curl",
        "tar":   "tar",
    }
    missing = []
    for binary, pkg in deps.items():
        if not shutil.which(binary):
            missing.append(pkg)
    if not missing:
        return True
    warn(f"Missing Termux packages: {', '.join(missing)}")
    info("Installing via pkg...")
    ret = os.system(f"pkg install -y {' '.join(missing)} 2>/dev/null")
    if ret != 0:
        ret = os.system(f"apt-get install -y {' '.join(missing)} 2>/dev/null")
    for binary, pkg in deps.items():
        if not shutil.which(binary) and pkg in missing:
            err(f"Failed to install: {pkg}")
            return False
    ok("All dependencies installed")
    return True


def preflight_checks():
    print(f"\n  {c('bold', 'Pre-flight checks...')}\n")

    # 1. Сеть
    sys.stdout.write(f"  {c('dim', '[ .... ]')} Network connectivity")
    sys.stdout.flush()
    if check_network():
        sys.stdout.write(f"\r  {c('green', '[  OK  ]')} Network connectivity\n")
    else:
        sys.stdout.write(f"\r  {c('red', '[ FAIL ]')} Network connectivity\n")
        warn("No internet — some features may not work")

    sys.stdout.flush()

    # 2. Зеркало Termux
    sys.stdout.write(f"  {c('dim', '[ .... ]')} Termux mirror")
    sys.stdout.flush()
    mirror_ok, mirror_url = check_termux_mirror()
    if mirror_ok:
        sys.stdout.write(f"\r  {c('green', '[  OK  ]')} Termux mirror ({mirror_url.split('/')[2]})\n")
    else:
        sys.stdout.write(f"\r  {c('yellow', '[  !!  ]')} Termux mirror unreachable — pkg may fail\n")
    sys.stdout.flush()

    # 3. Зависимости Termux
    sys.stdout.write(f"  {c('dim', '[ .... ]')} Termux dependencies (git, python3, proot, curl)")
    sys.stdout.flush()
    if install_termux_deps():
        sys.stdout.write(
            f"\r  {c('green', '[  OK  ]')} Termux dependencies installed          \n")
    else:
        sys.stdout.write(
            f"\r  {c('red', '[ FAIL ]')} Some dependencies missing                \n")
        err("Cannot continue without required packages")
        sys.exit(1)
    sys.stdout.flush()

    # 4. HOME
    sys.stdout.write(f"  {c('dim', '[ .... ]')} HOME environment")
    sys.stdout.flush()
    home = os.environ.get("HOME", "")
    if home and os.path.isdir(home):
        sys.stdout.write(f"\r  {c('green', '[  OK  ]')} HOME = {home}\n")
    else:
        sys.stdout.write(f"\r  {c('red', '[ FAIL ]')} HOME not set or missing\n")
        sys.exit(1)
    sys.stdout.flush()

    # 5. Целостность Asombi данных
    sys.stdout.write(f"  {c('dim', '[ .... ]')} Asombi data integrity")
    sys.stdout.flush()
    ensure_dirs()
    sys.stdout.write(f"\r  {c('green', '[  OK  ]')} Asombi directories OK\n")
    sys.stdout.flush()

    print()


def integrity_check(rootfs_dir):
    critical = [
        (os.path.join(rootfs_dir, "bin", "sh"),         "shell (busybox)"),
        (os.path.join(rootfs_dir, "etc"),                "/etc directory"),
        (os.path.join(rootfs_dir, "usr"),                "/usr directory"),
        (os.path.join(rootfs_dir, "etc", "profile"),     "/etc/profile"),
        (os.path.join(rootfs_dir, "etc", "resolv.conf"), "/etc/resolv.conf"),
    ]
    optional = [
        (os.path.join(rootfs_dir, "usr", "bin", "python3"),    "Python3"),
        (os.path.join(rootfs_dir, "usr", "bin", "curl"),       "curl"),
        (os.path.join(rootfs_dir, "usr", "bin", "apk"),        "Alpine apk"),
        (os.path.join(rootfs_dir, "usr", "local", "bin", "trk"), "Truck (trk)"),
    ]

    print(f"  {c('bold', 'Rootfs integrity check...')}\n")
    broken = []
    for path, desc in critical:
        exists = os.path.lexists(path)
        if exists:
            print(f"  {c('green', '✓')} {desc}")
        else:
            print(f"  {c('red', '✗')} {desc} — MISSING")
            broken.append(desc)

    for path, desc in optional:
        exists = os.path.lexists(path)
        status = c("green", "✓") if exists else c("yellow", "!")
        note = "" if exists else " (will be installed)"
        print(f"  {status} {desc}{note}")

    print()
    return broken


def cmd_login(name):
    print(BANNER)
    print(f"  {c('bold', 'Booting instance:')} {c('cyan', name)}\n")

    # Шаг 1: preflight — сеть, зеркала, зависимости Termux
    preflight_checks()

    ensure_dirs()
    rootfs = instance_rootfs(name)
    marker = os.path.join(rootfs, "etc", "alpine-release")

    if not os.path.exists(marker):
        info("First boot — setting up Alpine Linux...")
        arch = get_arch()
        ok(f"Architecture: {arch}")

        if not download_alpine(rootfs, arch):
            err("Alpine setup failed.")
            sys.exit(1)

        boot_sequence([
            "Configuring Alpine Linux",
            "Installing Truck package manager",
            "Setting up Asombi environment",
            "Configuring network DNS",
        ])

        setup_inside(rootfs, name)

        instances = load_instances()
        instances[name] = {
            "name":    name,
            "created": time.strftime("%Y-%m-%d %H:%M:%S"),
            "rootfs":  rootfs,
            "arch":    arch,
            "base":    f"Alpine Linux {ALPINE_VERSION}",
        }
        save_instances(instances)
        ok(f"Instance '{name}' ready")
    else:
        boot_sequence([
            "Loading Asombi kernel",
            "Mounting Alpine filesystem",
            "Starting session",
        ])

    # Шаг 2: проверка целостности rootfs
    broken = integrity_check(rootfs)
    if broken:
        critical_broken = [b for b in broken if b in (
            "shell (busybox)", "/etc directory", "/usr directory"
        )]
        if critical_broken:
            warn(f"Critical components missing: {', '.join(critical_broken)}")
            warn("Rootfs may be incomplete — trying to repair via apk")
        repair_cmd = (
            f"proot --link2symlink -0 -r {rootfs} "
            f"-b /dev -b /proc -b /sys "
            f"/bin/sh -c 'apk update -q 2>/dev/null && "
            f"apk add --no-cache python3 curl busybox -q 2>/dev/null'"
        )
        ret = os.system(repair_cmd)
        setup_inside(rootfs, name)
        if ret == 0:
            ok("Repair complete")
        else:
            warn("Repair may have failed — attempting to boot anyway")

    print(f"\n  {c('green', '✓')} Entering Asombi OS — {c('cyan', name)}\n")
    time.sleep(0.3)
    result = launch_proot(rootfs)
    if result is False:
        warn("Rootfs was corrupted and removed. Run: os login " + name + " again to reinstall.")
        return
    print(f"\n  {c('yellow', 'Session ended.')} Goodbye!\n")


def cmd_delete(args):
    if not args:
        err("Usage: os delete <name> | --all | --full")
        return

    instances = load_instances()
    flag = args[0]

    if flag == "--full":
        warn("This will delete ALL Asombi data:")
        print(f"  {ASOMBI_ROOT}")
        print(f"  Size: {human_size(size_of(ASOMBI_ROOT))}")
        confirm = input("\n  Are you sure? Type 'yes' to confirm: ").strip()
        if confirm != "yes":
            print("  Aborted.")
            return
        shutil.rmtree(ASOMBI_ROOT)
        ok("Asombi OS fully removed.")
        return

    if flag == "--all":
        if not instances:
            info("No instances to delete.")
            return
        warn(f"Deleting {len(instances)} instance(s):")
        for n in instances:
            print(f"  - {n}")
        confirm = input("\n  Are you sure? Type 'yes' to confirm: ").strip()
        if confirm != "yes":
            print("  Aborted.")
            return
        for n in list(instances.keys()):
            idir = instance_dir(n)
            if os.path.exists(idir):
                shutil.rmtree(idir)
            ok(f"Deleted: {n}")
        save_instances({})
        return

    name = flag
    if name not in instances:
        err(f"Instance '{name}' not found.")
        cmd_instances()
        return

    idir = instance_dir(name)
    size = human_size(size_of(idir)) if os.path.exists(idir) else "0 B"
    warn(f"Deleting instance '{name}' ({size})...")
    confirm = input("  Confirm? [y/N] ").strip().lower()
    if confirm != "y":
        print("  Aborted.")
        return
    if os.path.exists(idir):
        shutil.rmtree(idir)
    del instances[name]
    save_instances(instances)
    ok(f"Instance '{name}' deleted.")


def cmd_instances():
    instances = load_instances()
    if not instances:
        warn("No instances found.")
        print(f"  Create one: {c('cyan', 'os login asombi-1')}\n")
        return
    print(f"\n  {c('bold', 'Asombi instances:')}\n")
    for name, meta in instances.items():
        idir    = instance_dir(name)
        size    = human_size(size_of(idir)) if os.path.exists(idir) else "?"
        created = meta.get("created", "?")
        base    = meta.get("base", "?")
        print(f"  {c('cyan', name):<20} {base:<25} {size:<10} {c('dim', created)}")
    print()


def main():
    args = sys.argv[1:]

    if not args:
        print(BANNER)
        print(f"  Usage:")
        print(f"    {c('cyan', 'os login <name>')}         Start or create instance")
        print(f"    {c('cyan', 'os delete <name>')}        Delete instance (all files)")
        print(f"    {c('cyan', 'os delete --all')}         Delete all instances")
        print(f"    {c('cyan', 'os delete --full')}        Full removal (instances+cache+packages)")
        print(f"    {c('cyan', 'os instances')}            List all instances")
        print(f"    {c('cyan', 'os version')}              Show version\n")
        return

    cmd  = args[0]
    rest = args[1:]

    if cmd == "login":
        if not rest:
            err("Usage: os login <instance-name>")
            sys.exit(1)
        cmd_login(rest[0])
    elif cmd == "delete":
        cmd_delete(rest)
    elif cmd == "instances":
        cmd_instances()
    elif cmd == "version":
        print(f"  Asombi OS v{VERSION} | Alpine {ALPINE_VERSION}")
    else:
        err(f"Unknown command: '{cmd}'")
        print("  Run 'os' for help.")
        sys.exit(1)


if __name__ == "__main__":
    main()
